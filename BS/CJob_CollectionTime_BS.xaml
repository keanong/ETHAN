<?xml version="1.0" encoding="utf-8" ?>
<the49:BottomSheet xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:the49="https://schemas.the49.com/dotnet/2023/maui"
             x:Class="ETHAN.BS.CJob_CollectionTime_BS"
             BackgroundColor="{StaticResource Gray100}"
             x:Name="this"
             Padding="16, 32">
    <the49:BottomSheet.Resources>
        
        <Style TargetType="Border" x:Key="bb">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" 
                            Value="{StaticResource Gray100}" />
                                <Setter Property="HeightRequest" Value="50"></Setter>
                                <Setter Property="MinimumWidthRequest" Value="80"></Setter>

                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" 
                                Value="{StaticResource Yellow100Accent}" />
                                <Setter Property="HeightRequest" Value="50"></Setter>
                                <Setter Property="MinimumWidthRequest" Value="80"></Setter>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

    </the49:BottomSheet.Resources>

    <VerticalStackLayout Spacing="16">


        <StackLayout IsVisible="True" Spacing="10" Orientation="Horizontal" HorizontalOptions="FillAndExpand" VerticalOptions="Center">

            <Label x:Name="lblCD" Text="Ready Date" Style="{StaticResource textStyle16BlackBold}"
   VerticalOptions="Center" HorizontalOptions="Start"/>

            <Label x:Name="lblCDv" Text="" TextColor="Black" FontAttributes="Bold"
   VerticalOptions="Center" HorizontalOptions="Start" IsVisible="false"/>

            <Label x:Name="lblCDLTv" Text="" TextColor="Black" FontAttributes="Bold"
   VerticalOptions="Center" HorizontalOptions="Start" IsVisible="false"/>

            <Label x:Name="lblCDTv" Text="DateTime selected" Style="{StaticResource textStyle16BlackBold}"
   VerticalOptions="Center" HorizontalOptions="Start" IsVisible="false"/>
        </StackLayout>

        <StackLayout HorizontalOptions="FillAndExpand" VerticalOptions="Center" >

            <Border Padding="5" StrokeShape="RoundRectangle 20">

                <CollectionView x:Name="cvDate" SelectionChanged="cvDateOnItemSelected" SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="20" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource bb}" StrokeShape="RoundRectangle 20" Padding="5" Stroke="Black">
                                <Grid Padding="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!--default fontsize is 14-->
                                    <Label Text="{Binding dispText}" FontSize="12" FontAttributes="Bold" HorizontalOptions="FillAndExpand" HorizontalTextAlignment="Center" VerticalOptions="FillAndExpand" VerticalTextAlignment="Center" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <!--</StackLayout>-->

            </Border>

        </StackLayout>

        <StackLayout Spacing="10" Orientation="Horizontal" HorizontalOptions="FillAndExpand" VerticalOptions="Center">

            <Label Text="Any lunch time to avoid for Collection?" TextColor="Black" Style="{StaticResource textStyle16BlackBold}"
            VerticalOptions="Center" HorizontalOptions="Start" Padding="0"/>

        </StackLayout>


        <StackLayout HorizontalOptions="FillAndExpand" VerticalOptions="Center" >

            <Border Padding="5" StrokeShape="RoundRectangle 20">

                <CollectionView x:Name="cvColLunch" SelectionChanged="cvColLunchOnItemSelected" SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="20" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource bb}" StrokeShape="RoundRectangle 20" Padding="5" Stroke="Black">
                                <Grid Padding="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!--default fontsize is 14-->
                                    <Label Text="{Binding dispText}" FontSize="12" FontAttributes="Bold" HorizontalOptions="FillAndExpand" HorizontalTextAlignment="Center" VerticalOptions="FillAndExpand" VerticalTextAlignment="Center" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </Border>

        </StackLayout>

        <StackLayout Spacing="10" Orientation="Horizontal" HorizontalOptions="FillAndExpand" VerticalOptions="Center">

            <Label x:Name="lblReadyTimeV" Text="Ready Time" TextColor="Black" Style="{StaticResource textStyle16BlackBold}"
            VerticalOptions="Center" HorizontalOptions="Start" Padding="0"/>

            <Label x:Name="lblReadyTimeValue" Text="" TextColor="Black" FontAttributes="Bold"
            VerticalOptions="Center" HorizontalOptions="Start" IsVisible="False"/>

        </StackLayout>

        <StackLayout HorizontalOptions="FillAndExpand" VerticalOptions="Center" >

            <Border Padding="5" StrokeShape="RoundRectangle 20">

                <CollectionView x:Name="cvTime" SelectionChanged="cvTimeOnItemSelected" SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="20" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource bb}" StrokeShape="RoundRectangle 20" Padding="5" Stroke="Black">
                                <Grid Padding="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!--default fontsize is 14-->
                                    <Label Text="{Binding dispText}" FontSize="12" FontAttributes="Bold" HorizontalOptions="FillAndExpand" HorizontalTextAlignment="Center" VerticalOptions="FillAndExpand" VerticalTextAlignment="Center" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </Border>

        </StackLayout>

        <BoxView Style="{StaticResource Divider}" x:Name="divider1" />

        <StackLayout>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnCXSaveCollectionTime" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Cancel" Style="{StaticResource bstyleOrange}" Clicked="btnCXSaveCollectionTimeClick" />
                <Button x:Name="btnSaveCollectionTime" Grid.Row="0" Grid.Column="3" Grid.ColumnSpan="2" Text="Save" Style="{StaticResource bstyleOrange}" Clicked="btnSaveCollectionTimeClick" />

            </Grid>

        </StackLayout>

    </VerticalStackLayout>

</the49:BottomSheet>
    