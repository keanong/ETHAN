<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ETHAN.Views.AddressPage"
             xmlns:beh="clr-namespace:ETHAN.classes"
             HideSoftInputOnTapped="True"
             BackgroundColor="Transparent"
             Shell.BackgroundColor="Transparent"
             Shell.NavBarIsVisible="False"
             Title="Address"
             Padding="0"
             SafeAreaEdges="All">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ContentPage.Resources>
        <Style x:Key="txt" TargetType="Entry">
            <Setter Property="HeightRequest" Value="38"/>
            <Setter Property="TextColor" Value="Black"/>
            <Setter Property="HorizontalTextAlignment" Value="Center"/>
            <Setter Property="VerticalTextAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="Border" x:Key="bb">
            <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Stroke" Value="Black"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BackgroundColor" Value="{StaticResource Gray100}"/>
            <Setter Property="HeightRequest" Value="50"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" 
                                    Value="{StaticResource Gray100}" />
                                <Setter Property="HeightRequest" Value="50"></Setter>
                                <Setter Property="MinimumWidthRequest" Value="50"></Setter>

                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" 
                                        Value="{StaticResource XDelOrange}" />
                                <Setter Property="HeightRequest" Value="50"></Setter>
                                <Setter Property="MinimumWidthRequest" Value="50"></Setter>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>



        <Style TargetType="Border" x:Key="bbtxt">
            <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
            <Setter Property="Stroke" Value="{StaticResource Gray200}"/>
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="Border" x:Key="bbtxt2">
            <Setter Property="StrokeShape" Value="RoundRectangle 20"></Setter>
            <Setter Property="Stroke" Value="{StaticResource Gray50}"></Setter>
            <Setter Property="BackgroundColor" Value="{StaticResource Gray50}"></Setter>
            <Setter Property="Padding" Value="5"></Setter>
        </Style>

    </ContentPage.Resources>

    <Grid>
        <!-- SAFE AREA CONTAINER -->
        <Grid x:Name="RootLayout" Padding="{OnPlatform iOS='0,0,0,0', Android='0'}">
            
            <Border x:Name="AppContainer" VerticalOptions="Fill" HorizontalOptions="Center" BackgroundColor="{StaticResource Gray50}" 
                Padding="0" MaximumWidthRequest="{OnIdiom Phone=99999, Tablet=500}">
                <!-- This Grid acts as a z-stack -->
                <Grid>

                    <!-- Internal layout of the card -->
                    <Grid RowDefinitions="Auto,*" BackgroundColor="Transparent">

                        <Grid HeightRequest="60" BackgroundColor="{StaticResource Gray50}" 
                          HorizontalOptions="Start" VerticalOptions="Start" ColumnDefinitions="Auto,*" Padding="0,0">

                            <ImageButton Source="arrow_left_80.png" Clicked="Back" BackgroundColor="Transparent" VerticalOptions="Center" 
                                           WidthRequest="{OnIdiom Phone=30, Tablet=40}" HeightRequest="{OnIdiom Phone=30, Tablet=40}"/>
                            <Label x:Name="btnTopNBack" Grid.Column="1" Text="Address" FontSize="20" FontAttributes="Bold" 
                               TextColor="{StaticResource XDelOrange}" VerticalOptions="Center" VerticalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="Back"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <ScrollView Grid.Row="1" Padding="10,0,10,10" Margin="0" HorizontalOptions="Fill">
                            <VerticalStackLayout Spacing="10">

                                <Grid ColumnDefinitions="*,*" HorizontalOptions="Fill" ColumnSpacing="5">
                                    <Button Grid.Column="0" x:Name="btnDefAddress" Text="Account's Address" Style="{StaticResource bstyleOrange}" Clicked="btnDefAddress_Clicked" />
                                    <Button Grid.Column="0" x:Name="btnNewAddress" Text="New Address" Style="{StaticResource bstyleOrange}" IsVisible="False" Clicked="btnNewAddress_Clicked" />
                                    <Button Grid.Column="1" x:Name="btnAddressBk" Text="Address Book" Style="{StaticResource bstyleOrange}" Clicked="btnAddressBk_Clicked" />
                                </Grid>

                                <Grid ColumnDefinitions="*,*,*" HorizontalOptions="Fill" ColumnSpacing="5">

                                    <Border Grid.Column="0" Style="{StaticResource bbtxt}" HeightRequest="55" HorizontalOptions="Fill">

                                        <Grid RowDefinitions="*,*" HorizontalOptions="Fill">
                                            <Label Grid.Row="0" Text="Postal*" HorizontalOptions="Fill" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                            <Label x:Name="lblSelectedPostal" Text="" IsVisible="False" />
                                            <Entry Grid.Row="1" x:Name="txtPostal" Keyboard="Numeric" MaxLength="6" Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="Fill" Margin="6,0,0,0" ReturnType="Done">
                                                <Entry.Behaviors>
                                                    <beh:NumericEntryBehavior AllowEmpty="True" IsNumberOnly="True" />
                                                </Entry.Behaviors>
                                            </Entry>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource bbtxt}" HeightRequest="55">
                                        <Grid RowDefinitions="*,*" HorizontalOptions="FillAndExpand">
                                            <Label Grid.Row="0" Text="Block" HorizontalOptions="FillAndExpand" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                            <Entry Grid.Row="1" x:Name="txtBlock" Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="FillAndExpand" Margin="6,0,0,0" ReturnType="Done">
                                                <Entry.Behaviors>
                                                    <beh:UpperCaseEntryBehavior />
                                                </Entry.Behaviors>
                                            </Entry>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource bbtxt}" HeightRequest="55">
                                        <Grid RowDefinitions="*,*" HorizontalOptions="FillAndExpand">
                                            <Label Grid.Row="0" Text="Unit" HorizontalOptions="FillAndExpand" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                            <Entry Grid.Row="1" x:Name="txtUnit" Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="FillAndExpand" Margin="6,0,0,0" ReturnType="Done">
                                                <Entry.Behaviors>
                                                    <beh:UpperCaseEntryBehavior />
                                                </Entry.Behaviors>
                                            </Entry>
                                        </Grid>
                                    </Border>

                                </Grid>

                                <Border Style="{StaticResource bbtxt}" HeightRequest="55">
                                    <Grid RowDefinitions="*,*" HorizontalOptions="FillAndExpand">
                                        <Label Grid.Row="0" Text="Street*" HorizontalOptions="FillAndExpand" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                        <Entry Grid.Row="1" x:Name="txtStreet" Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="FillAndExpand" Margin="6,0,0,0" ReturnType="Done">
                                            <Entry.Behaviors>
                                                <beh:UpperCaseEntryBehavior />
                                            </Entry.Behaviors>
                                        </Entry>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource bbtxt}" HeightRequest="55">
                                    <Grid RowDefinitions="*,*" HorizontalOptions="FillAndExpand">
                                        <Label Grid.Row="0" Text="Building Name" HorizontalOptions="FillAndExpand" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                        <Entry Grid.Row="1" x:Name="txtBldg" Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="FillAndExpand" Margin="6,0,0,0" ReturnType="Done">
                                            <Entry.Behaviors>
                                                <beh:UpperCaseEntryBehavior />
                                            </Entry.Behaviors>
                                        </Entry>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource bbtxt}" HeightRequest="55">
                                    <Grid RowDefinitions="*,*" HorizontalOptions="FillAndExpand">
                                        <Label Grid.Row="0" Text="Company Name" HorizontalOptions="FillAndExpand" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                        <Entry Grid.Row="1" x:Name="txtCompany" Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="FillAndExpand" Margin="6,0,0,0" ReturnType="Done">
                                            <Entry.Behaviors>
                                                <beh:UpperCaseEntryBehavior />
                                            </Entry.Behaviors>
                                        </Entry>
                                    </Grid>
                                </Border>

                                <CollectionView x:Name="cvLocationType" SelectionMode="Single" SelectionChanged="cvLocationTypeOnItemSelected"
                                ItemsLayout="HorizontalList" HeightRequest="55">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource bb}" Margin="0,0,5,0">
                                                <Label Text="{Binding dispText}" HorizontalOptions="Center" VerticalOptions="Center" 
                                                       HorizontalTextAlignment="Center" Style="{StaticResource textStyle14Black}" />
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <Border Style="{StaticResource bbtxt}" HeightRequest="55">
                                    <Grid RowDefinitions="*,*" HorizontalOptions="FillAndExpand">
                                        <Label Grid.Row="0" Text="Contact Name*" HorizontalOptions="FillAndExpand" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                        <Entry Grid.Row="1" x:Name="txtContactName" Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="FillAndExpand" Margin="6,0,0,0" ReturnType="Done">
                                            <Entry.Behaviors>
                                                <beh:UpperCaseEntryBehavior />
                                            </Entry.Behaviors>
                                        </Entry>
                                    </Grid>
                                </Border>

                                <Grid ColumnDefinitions="*,*" HorizontalOptions="FillAndExpand" ColumnSpacing="5">

                                    <Border Grid.Column="0" Style="{StaticResource bbtxt}" HeightRequest="55">
                                        <Grid RowDefinitions="*,*" HorizontalOptions="FillAndExpand">
                                            <Label Grid.Row="0" Text="Tel" HorizontalOptions="FillAndExpand" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                            <Entry Grid.Row="1" x:Name="txtTel" Keyboard="Numeric" MaxLength="8"  Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="FillAndExpand" Margin="6,0,0,0" ReturnType="Done">
                                                <Entry.Behaviors>
                                                    <beh:NumericEntryBehavior AllowEmpty="True" IsNumberOnly="True" />
                                                </Entry.Behaviors>
                                            </Entry>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource bbtxt}" HeightRequest="55">
                                        <Grid RowDefinitions="*,*" HorizontalOptions="FillAndExpand">
                                            <Label Grid.Row="0" Text="Mobile" HorizontalOptions="FillAndExpand" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                            <Entry Grid.Row="1" x:Name="txtHp" Keyboard="Numeric" MaxLength="8"  Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="FillAndExpand" Margin="6,0,0,0" ReturnType="Done">
                                                <Entry.Behaviors>
                                                    <beh:NumericEntryBehavior AllowEmpty="True" IsNumberOnly="True" />
                                                </Entry.Behaviors>
                                            </Entry>
                                        </Grid>
                                    </Border>

                                </Grid>

                                <Label Text="Please enter at least a Tel or Mobile Number." Style="{StaticResource textStyle15Black}" Margin="10,0,0,0" />

                                <Border Style="{StaticResource bbtxt}" HeightRequest="55">
                                    <Grid RowDefinitions="*,*" HorizontalOptions="FillAndExpand">
                                        <Label x:Name="lblInstructions_PlaceholderText" Grid.Row="0" Text="Instruction" HorizontalOptions="FillAndExpand" VerticalOptions="Center" TextColor="Gray" Margin="10,0,0,0" />
                                        <Entry Grid.Row="1" x:Name="txtInstruction" Style="{StaticResource txt}" 
                                                    HorizontalTextAlignment="Start" HorizontalOptions="FillAndExpand" Margin="6,0,0,0" ReturnType="Done">
                                            <Entry.Behaviors>
                                                <beh:UpperCaseEntryBehavior />
                                            </Entry.Behaviors>
                                        </Entry>
                                    </Grid>
                                </Border>

                                <CollectionView x:Name="cvSlot" SelectionMode="Multiple"  SelectionChanged="cvSlotOnItemSelected"
                                ItemsLayout="HorizontalList" HeightRequest="55">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource bb}" Margin="0,0,5,0">
                                                <Label Text="{Binding dispText}" HorizontalOptions="Center" VerticalOptions="Center" 
                                                       HorizontalTextAlignment="Center" Style="{StaticResource textStyle14Black}" />
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <Label x:Name="lblv1" Text="v1" IsVisible="False"></Label>
                                <Label x:Name="lblv2" Text="v2" IsVisible="False"></Label>

                                <Grid ColumnDefinitions="*,*" HorizontalOptions="Fill" ColumnSpacing="5">
                                    <Button Grid.Column="0" x:Name="btnCancel" Text="Cancel" Style="{StaticResource bstyleOrange}" Clicked="btnCancel_Clicked" />
                                    <Button Grid.Column="1" x:Name="btnSave" Text="Save" Style="{StaticResource bstyleOrange}" Clicked="btnSave_Clicked" />
                                </Grid>
                            </VerticalStackLayout>
                        </ScrollView>

                    </Grid>

                </Grid>

            </Border>

        </Grid>

    </Grid>
</ContentPage>