<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ETHAN.Views.BottomSheetDatePicker"
             BackgroundColor="#80000000"
    IsVisible="False"
             Opacity="0">

    <Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
        <!-- Detect tap outside -->
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="Overlay_Tapped"/>
        </Grid.GestureRecognizers>

        <Grid VerticalOptions="End" HorizontalOptions="FillAndExpand">
            <Border x:Name="SheetContainer"
                BackgroundColor="White"
                Stroke="Gray"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10,10,0,0"
                Padding="10"
                VerticalOptions="End"
                HeightRequest="300">

                <VerticalStackLayout>
                    <DatePicker x:Name="Picker" VerticalOptions="CenterAndExpand"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="20" Margin="0,10,0,0">
                        <Button Text="Cancel" Clicked="Cancel_Clicked"/>
                        <Button Text="OK" Clicked="Ok_Clicked"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
    
</ContentView>