<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net10.0-android;net10.0-ios</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<RootNamespace>ETHAN</RootNamespace>
		<UseMaui>true</UseMaui>
		<SingleProject>true</SingleProject>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<ApplicationTitle>ETHAN</ApplicationTitle>
		<ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
		<ApplicationVersion>1</ApplicationVersion>

		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">15.0</SupportedOSPlatformVersion>
		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">25.0</SupportedOSPlatformVersion>

		<!-- Android signing -->
		<AndroidSigningKeyStore>Ethan.keystore</AndroidSigningKeyStore>
	</PropertyGroup>

	<!-- iOS Signing -->
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
		<CodesignKey>iPhone Developer</CodesignKey>
		<CodesignProvision>iOS Team Provisioning Profile: com.xdel.ethan</CodesignProvision>
	</PropertyGroup>
	<!-- <PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
		<CodesignKey>iPhone Developer</CodesignKey>
		<CodesignProvision></CodesignProvision>
		<AutomaticProvisioning>true</AutomaticProvisioning>
	</PropertyGroup> -->
	

	<!-- Debug Android -->
	<PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Debug|net10.0-android|AnyCPU'">
		<AndroidKeyStore>True</AndroidKeyStore>
		<AndroidSigningStorePass>12321qwE</AndroidSigningStorePass>
		<AndroidSigningKeyAlias>Ethan</AndroidSigningKeyAlias>
		<AndroidSigningKeyPass>12321qwE</AndroidSigningKeyPass>
		<ApplicationId>com.xdel.ethan</ApplicationId>
		<AndroidEnableFastDeployment>true</AndroidEnableFastDeployment>
		<AndroidFastDeploymentType>Assemblies</AndroidFastDeploymentType>
		<AndroidUseSharedRuntime>true</AndroidUseSharedRuntime>
		<AndroidLinkMode>None</AndroidLinkMode>
		<RunAOTCompilation>false</RunAOTCompilation>
		<UseInterpreter>true</UseInterpreter>
		<JavaMaximumHeapSize>2G</JavaMaximumHeapSize>
	</PropertyGroup>

	<!-- Debug iOS -->
	<PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Debug|net10.0-ios|AnyCPU'">
		<ApplicationId>com.xdel.ethan</ApplicationId>
		<MtouchLink>None</MtouchLink>
		<MtouchFastDev>true</MtouchFastDev>
		<MtouchUseLlvm>false</MtouchUseLlvm>
		<RunAOTCompilation>false</RunAOTCompilation>
		<UseInterpreter>true</UseInterpreter>
		<BuildIpa>false</BuildIpa>
		<MtouchDebug>true</MtouchDebug>
		<Optimize>false</Optimize>
	</PropertyGroup>

	<!-- Release Android -->
	<PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Release|net10.0-android|AnyCPU'">
		<AndroidPackageFormat>apk</AndroidPackageFormat>
		<AndroidKeyStore>True</AndroidKeyStore>
		<AndroidSigningStorePass>12321qwE</AndroidSigningStorePass>
		<AndroidSigningKeyAlias>Ethan</AndroidSigningKeyAlias>
		<AndroidSigningKeyPass>12321qwE</AndroidSigningKeyPass>
		<ApplicationId>com.xdel.ethan</ApplicationId>
		<AndroidEnableFastDeployment>false</AndroidEnableFastDeployment>
		<AndroidUseSharedRuntime>false</AndroidUseSharedRuntime>
		<AndroidLinkMode>SdkOnly</AndroidLinkMode>
		<RunAOTCompilation>true</RunAOTCompilation>
		<JavaMaximumHeapSize>2G</JavaMaximumHeapSize>
	</PropertyGroup>

	<!-- Release iOS -->
	<PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Release|net10.0-ios|AnyCPU'">
		<ApplicationId>com.xdel.ethan</ApplicationId>
		<!--<MtouchLink>SdkOnly</MtouchLink>-->
		<MtouchLink>None</MtouchLink>
		<MtouchUseLlvm>false</MtouchUseLlvm>
		<RunAOTCompilation>false</RunAOTCompilation>
		<UseInterpreter>true</UseInterpreter>
		<MtouchDebug>false</MtouchDebug>
		<BuildIpa>true</BuildIpa>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(TargetFramework)'=='net10.0-ios'">
	  <ProvisioningType>manual</ProvisioningType>
	</PropertyGroup>

	<ItemGroup>
		<!-- Launcher icon and splash screen -->
		<!--<MauiIcon Include="Resources/AppIcon/test_p.png" ForegroundFile="Resources/AppIcon/test_p.png" Color="#FFFFFF" />-->
		<!-- <MauiIcon Include="Resources/AppIcon/test_p.png" Color="#FFFFFF" /> -->
		<MauiSplashScreen Include="Resources\Splash\xdel_transparent_512.png" Color="#ffffff" BaseSize="256,256" />

		<!-- Images, fonts, raw assets -->
		<MauiImage Include="Resources/Images/*" />
		<MauiImage Update="Resources\Images\dotnet_bot.png" Resize="True" BaseSize="300,185" />
		<MauiFont Include="Resources\Fonts\*" />
		<MauiAsset Include="Resources\Raw\**" LogicalName="%(RecursiveDir)%(Filename)%(Extension)" />
	</ItemGroup>

